# Created for: aws-fieldbook (markdown + scripts + terraform examples)
# Source: github.com/github/gitignore

### macOS / Windows / Linux ###
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

### Editors ###
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.sublime-project
*.sublime-workspace

### AWS - NEVER COMMIT THESE ###
.aws/
*.pem
*.ppk
id_rsa
id_ed25519
*.key
credentials
config
.env
.env.*
*.tfvars
*.tfvars.json

### Terraform ###
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
terraform.tfplan
terraform.tfplan.*
terraform.tfstate
terraform.tfstate.*

### Keep lock file (good practice) ###
# !.terraform.lock.hcl

### Terragrunt ###
.terragrunt-cache/

### Python (for helper scripts) ###
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv
pip-log.txt
pip-delete-this-directory.txt

### Node / CDK ###
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
cdk.out/
.cdk.staging/
dist/

### Logs ###
*.log
logs/

### Build artifacts ###
*.zip
*.tar.gz
*.tgz
*.rar

### Keep folder structure ###
!**/images/.gitkeep
!**/commands/.gitkeep
!**/terraform/.gitkeep
